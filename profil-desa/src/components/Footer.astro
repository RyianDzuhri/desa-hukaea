---
import {
    MapPin,
    Phone,
    Mail,
    Facebook,
    Instagram,
    Youtube,
} from "lucide-astro";

import logo from "../assets/images/logo-desa.png";
import { village } from "../data/village";
---

<footer class="relative mt-16 overflow-hidden bg-gradient-to-br from-slate-950 via-slate-900 to-green-950 text-white">

    <!-- Background -->
    <div class="absolute -left-40 -top-40 h-80 w-80 rounded-full bg-green-500/20 blur-[140px]"></div>

    <div class="absolute -right-40 bottom-0 h-80 w-80 rounded-full bg-emerald-500/20 blur-[140px]"></div>

    <div class="container relative z-10 mx-auto max-w-7xl px-6 pt-20 pb-8">

        <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">

            <!-- Logo -->

            <div>

                <div class="flex items-center gap-4">

                    <img
                        src={logo.src}
                        alt="Logo Desa"
                        class="h-14 w-14 object-contain"
                    />

                    <div>

                        <h3 class="text-2xl font-bold">
                            {village.name}
                        </h3>

                        <p class="text-sm text-slate-300">
                            Website Resmi Desa
                        </p>

                    </div>

                </div>

                <p class="mt-5 max-w-xs text-base leading-8 text-slate-400">
                    {village.description}
                </p>

            </div>

            <!-- Navigasi -->

            <div>

                <h4 class="text-xl font-semibold">
                    Navigasi
                </h4>

                <ul class="mt-5 space-y-4">

                    <li>
                        <a
                            href="#beranda"
                            class="text-slate-400 transition hover:text-green-400"
                        >
                            Beranda
                        </a>
                    </li>

                    <li>
                        <a
                            href="#profil"
                            class="text-slate-400 transition hover:text-green-400"
                        >
                            Profil
                        </a>
                    </li>

                    <li>
                        <a
                            href="#potensi"
                            class="text-slate-400 transition hover:text-green-400"
                        >
                            Potensi
                        </a>
                    </li>

                    <li>
                        <a
                            href="#galeri"
                            class="text-slate-400 transition hover:text-green-400"
                        >
                            Galeri
                        </a>
                    </li>

                    <li>
                        <a
                            href="#kontak"
                            class="text-slate-400 transition hover:text-green-400"
                        >
                            Kontak
                        </a>
                    </li>

                </ul>

            </div>

            <!-- Kontak -->

            <div>

                <h4 class="text-xl font-semibold">
                    Kontak
                </h4>

                <div class="mt-5 space-y-5">

                    <div class="flex items-start gap-3">

                        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-green-500/10">

                            <MapPin class="h-5 w-5 text-green-400" />

                        </div>

                        <p class="text-slate-400 leading-7">
                            {village.contact.address}
                        </p>

                    </div>

                    <div class="flex items-center gap-3">

                        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-green-500/10">

                            <Phone class="h-5 w-5 text-green-400" />

                        </div>

                        <p class="text-slate-400">
                            {village.contact.phone}
                        </p>

                    </div>

                    <div class="flex items-center gap-3">

                        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-green-500/10">

                            <Mail class="h-5 w-5 text-green-400" />

                        </div>

                        <p class="break-all text-slate-400">
                            {village.contact.email}
                        </p>

                    </div>

                </div>

            </div>

            <!-- Sosial Media -->

            <div>

                <h4 class="text-xl font-semibold">
                    Ikuti Kami
                </h4>

                <p class="mt-5 text-slate-400 leading-7">
                    Ikuti media sosial resmi Desa Hukaea untuk memperoleh informasi terbaru.
                </p>

                <div class="mt-6 flex gap-3">

                    <a
                        href="#"
                        class="flex h-12 w-12 items-center justify-center rounded-xl bg-white/10 transition-all duration-300 hover:-translate-y-1 hover:bg-green-600"
                    >
                        <Facebook class="h-5 w-5" />
                    </a>

                    <a
                        href="#"
                        class="flex h-12 w-12 items-center justify-center rounded-xl bg-white/10 transition-all duration-300 hover:-translate-y-1 hover:bg-green-600"
                    >
                        <Instagram class="h-5 w-5" />
                    </a>

                    <a
                        href="#"
                        class="flex h-12 w-12 items-center justify-center rounded-xl bg-white/10 transition-all duration-300 hover:-translate-y-1 hover:bg-green-600"
                    >
                        <Youtube class="h-5 w-5" />
                    </a>

                </div>

            </div>

        </div>

        <!-- Bottom -->

        <div class="mt-10 border-t border-white/10 pt-6">

            <div class="flex flex-col items-center justify-between gap-3 text-sm text-slate-500 md:flex-row">

                <p>
                    © 2026 <span class="font-semibold text-slate-300">Desa Hukaea</span>. Seluruh hak cipta dilindungi.
                </p>

                <p class="text-center md:text-right">
                    Dikembangkan oleh:
                    <span class="font-semibold text-green-400">
                        Mahasiswa KKN Universitas Halu Oleo
                    </span>
                </p>

            </div>

        </div>

    </div>

</footer>