---
import { ImageOff } from "lucide-astro";
import { village } from "../data/village";
---

<section
    id="galeri"
    class="relative overflow-hidden bg-slate-50 py-32"
>

    <!-- Background -->
    <div class="absolute -left-40 top-0 h-96 w-96 rounded-full bg-green-100/60 blur-[120px]"></div>
    <div class="absolute -right-40 bottom-0 h-96 w-96 rounded-full bg-emerald-100/60 blur-[120px]"></div>

    <div class="container relative z-10 mx-auto px-6">

        <!-- Heading -->

        <div class="mx-auto max-w-3xl text-center">

            <span
                class="inline-flex rounded-full bg-green-100 px-5 py-2 text-sm font-semibold text-green-700"
            >
                Galeri Desa
            </span>

            <h2
                class="mt-6 text-5xl font-black text-slate-900"
            >
                Dokumentasi Desa Hukaea
            </h2>

            <p
                class="mt-6 text-lg leading-8 text-slate-500"
            >
                Dokumentasi berbagai kegiatan, potensi, dan suasana
                Desa Hukaea.
            </p>

        </div>

        <!-- Gallery -->

        <div
            class="mt-20 grid gap-8 lg:grid-cols-[2fr_1fr]"
        >

            <!-- Hero Image -->

            <div
                id="gallery-preview"
                class="group relative overflow-hidden rounded-[36px] bg-white shadow-[0_25px_70px_rgba(0,0,0,.08)]"
            >

                <!-- Gambar Preview -->
                <img
                    id="preview-image"
                    src=""
                    alt=""
                    class="hidden h-[500px] w-full object-cover transition-opacity duration-300"
                />

                <!-- Placeholder -->
                <div
                    id="preview-placeholder"
                    class="flex h-[500px] items-center justify-center bg-gradient-to-br from-green-50 via-white to-green-100"
                >

                    <div class="text-center">

                        <div
                            class="mx-auto flex h-28 w-28 items-center justify-center rounded-[28px] bg-green-100"
                        >
                            <ImageOff
                                class="h-14 w-14 text-green-600"
                            />
                        </div>

                        <h3
                            id="preview-title"
                            class="mt-8 text-3xl font-bold text-slate-900"
                        >
                            {village.gallery[0].title}
                        </h3>

                        <p class="mt-3 text-slate-500">
                            Foto akan ditampilkan di sini.
                        </p>

                    </div>

                </div>

            </div>

            <!-- Thumbnail -->

            <div
                class="space-y-5"
            >

                {
                    village.gallery.map((item, index) => (

                        <button
                            type="button"
                            class={`gallery-item w-full overflow-hidden rounded-3xl border transition-all duration-300 ${
                                index === 0
                                    ? "border-green-500 shadow-lg"
                                    : "border-transparent hover:border-green-300"
                            }`}
                            data-title={item.title}
                            data-image={item.image ?? ""}
                        >

                            <div
                                class="flex h-18 items-center gap-3 bg-white px-4"
                            >

                                <div
                                    class="flex h-14 w-14 items-center justify-center rounded-xl bg-green-100"
                                >

                                    <ImageOff
                                        class="h-10 w-10 text-green-600"
                                    />

                                </div>

                                <div
                                    class="text-left"
                                >

                                    <h3
                                        class="font-semibold text-slate-900"
                                    >
                                        {item.title}
                                    </h3>

                                    <p
                                        class="mt-1 text-sm text-slate-500"
                                    >
                                        Dokumentasi Desa
                                    </p>

                                </div>

                            </div>

                        </button>

                    ))
                }

            </div>

        </div>

    </div>

</section>

<script>
document.addEventListener("DOMContentLoaded", () => {

    const previewImage = document.getElementById("preview-image");
    const previewPlaceholder = document.getElementById("preview-placeholder");
    const previewTitle = document.getElementById("preview-title");

    if (!previewImage || !previewPlaceholder || !previewTitle) return;

    const items = document.querySelectorAll(".gallery-item");

    items.forEach((item) => {

        item.addEventListener("click", () => {

            // Hapus status aktif
            items.forEach((el) => {
                el.classList.remove(
                    "border-green-500",
                    "shadow-lg"
                );

                el.classList.add("border-transparent");
            });

            // Aktifkan thumbnail yang dipilih
            item.classList.remove("border-transparent");
            item.classList.add(
                "border-green-500",
                "shadow-lg"
            );

            const title = item.getAttribute("data-title") || "";
            const image = item.getAttribute("data-image") || "";

            previewImage.classList.add("opacity-0");

            setTimeout(() => {

                previewTitle.textContent = title;

                if (image !== "") {

                    previewImage.setAttribute("src", image);

                    previewImage.classList.remove("hidden");

                    previewPlaceholder.classList.add("hidden");

                } else {

                    previewImage.classList.add("hidden");

                    previewPlaceholder.classList.remove("hidden");

                }

                previewImage.classList.remove("opacity-0");

            }, 200);

        });

    });

});
</script>