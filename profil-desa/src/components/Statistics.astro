---
import {
    Users,
    House,
    MapPinned,
    Map,
    Store,
} from "lucide-astro";

import { village } from "../data/village";

const stats = [
    {
        title: "Penduduk",
        value: village.statistics.population.toLocaleString("id-ID"),
        icon: Users,
    },
    {
        title: "Kepala Keluarga",
        value: village.statistics.households,
        icon: House,
    },
    {
        title: "Dusun",
        value: village.statistics.hamlets,
        icon: MapPinned,
    },
    {
        title: "Luas Wilayah",
        value: village.statistics.area,
        icon: Map,
    },
    {
        title: "UMKM",
        value: village.statistics.umkm,
        icon: Store,
    },
];
---

<section class="relative overflow-hidden py-32">

    <!-- Background Decoration -->
    <div class="absolute -left-40 top-0 h-96 w-96 rounded-full bg-green-100/60 blur-[120px]"></div>
    <div class="absolute -right-40 bottom-0 h-96 w-96 rounded-full bg-emerald-100/60 blur-[120px]"></div>

    <div class="container relative z-10 mx-auto px-6">

        <div class="mb-20 text-center">

            <span class="inline-flex rounded-full bg-green-100 px-5 py-2 text-sm font-semibold text-green-700">
                Statistik Desa
            </span>

            <h2 class="mt-6 text-5xl font-black tracking-tight text-slate-900">
                Gambaran Singkat Desa Hukaea
            </h2>

            <p class="mx-auto mt-5 max-w-3xl text-lg leading-relaxed text-slate-500">
                Data umum yang menggambarkan kondisi Desa Hukaea secara keseluruhan.
            </p>

        </div>

        <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-5">

            {
                stats.map((item) => {
                    const Icon = item.icon;

                    return (
                        <div
                            class="group flex min-h-[260px] flex-col items-center justify-center rounded-[32px] border border-white/60 bg-white/80 p-8 text-center backdrop-blur-xl shadow-[0_15px_45px_rgba(0,0,0,.08)] transition-all duration-500 hover:-translate-y-4 hover:shadow-[0_25px_60px_rgba(22,163,74,.18)]"
                        >

                            <div
                                class="flex h-20 w-20 items-center justify-center rounded-3xl bg-gradient-to-br from-green-100 to-green-50 transition-all duration-500 group-hover:scale-110 group-hover:rotate-6 group-hover:from-green-600 group-hover:to-emerald-500"
                            >
                                <Icon
                                    class="h-10 w-10 text-green-600 transition-colors duration-500 group-hover:text-white"
                                    strokeWidth={2}
                                />
                            </div>

                            <h3 class="mt-8 text-5xl font-black tracking-tight text-slate-900">
                                {item.value}
                            </h3>

                            <p class="mt-3 text-lg font-medium text-slate-500">
                                {item.title}
                            </p>

                        </div>
                    );
                })
            }

        </div>

    </div>

</section>