---
import { Check, ArrowRight } from "lucide-astro";
import { village } from "../data/village";
import aboutImage from "../assets/images/about-desa.jpg";
---

<section
    id="profil"
    class="relative overflow-hidden py-32"
>
    <!-- Background Blur -->

    <div
        class="absolute -left-40 top-20 h-[420px] w-[420px] rounded-full bg-green-100 blur-[140px]"
    />

    <div
        class="absolute -right-40 bottom-0 h-[420px] w-[420px] rounded-full bg-emerald-100 blur-[140px]"
    />

    <div class="container relative z-10 mx-auto px-6">

        <div class="grid items-center gap-20 lg:grid-cols-[0.7fr_1.3fr]">

            <!-- FOTO -->

            <div class="relative mx-auto w-full max-w-[380px]">

                <img
                    src={aboutImage.src}
                    alt="Desa Hukaea"
                    class="h-[470px] w-full rounded-[30px] object-cover shadow-[0_20px_60px_rgba(0,0,0,.12)]"
                />

                <div
                    class="absolute bottom-5 right-5 rounded-2xl border border-white/40 bg-white/90 px-5 py-4 backdrop-blur-xl shadow-lg"
                >
                    <p class="text-xs text-gray-500">
                        Kabupaten
                    </p>

                    <h3 class="text-lg font-bold text-slate-900">
                        Bombana
                    </h3>
                </div>

            </div>

            <!-- CONTENT -->

            <div>

                <span
                    class="inline-flex rounded-full bg-green-100 px-5 py-2 text-sm font-semibold text-green-700"
                >
                    Tentang Desa
                </span>

                <h2
                    class="mt-6 max-w-3xl text-5xl font-black leading-tight text-slate-900"
                >
                    Membangun Desa yang Modern, Transparan, dan Berkelanjutan.
                </h2>

                <p
                    class="mt-8 max-w-3xl text-lg leading-9 text-slate-600"
                >
                    {village.about.description}
                </p>

                <div class="mt-10 grid gap-5 sm:grid-cols-2">

                    {
                        village.about.highlights.map((item) => (
                            <div class="flex items-center gap-4">

                                <div
                                    class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-green-100"
                                >
                                    <Check
                                        class="h-5 w-5 text-green-700"
                                    />
                                </div>

                                <span
                                    class="text-base text-slate-700"
                                >
                                    {item}
                                </span>

                            </div>
                        ))
                    }

                </div>

                <a
                    href="#potensi"
                    class="group mt-12 inline-flex items-center gap-3 rounded-2xl bg-green-600 px-8 py-4 font-semibold text-white transition-all duration-300 hover:bg-green-700 hover:shadow-xl"
                >
                    Jelajahi Potensi Desa

                    <ArrowRight
                        class="transition-transform duration-300 group-hover:translate-x-1"
                    />

                </a>

            </div>

        </div>

    </div>

</section>