---
import logoDesa from "../assets/images/logo-desa.png";
---

<header id="navbar" class="navbar">
    <div class="container mx-auto flex h-20 items-center justify-between px-6">

        <!-- Logo -->
        <a href="#beranda" class="flex items-center gap-3">

            <img
                src={logoDesa.src}
                alt="Logo Desa"
                class="h-12 w-12 object-contain"
            />

            <div class="leading-tight">
                <h1 class="font-bold text-xl">
                    Desa Hukaea
                </h1>

                <p class="text-sm">
                    Website Resmi Desa
                </p>
            </div>

        </a>

        <!-- Menu -->
        <nav class="hidden md:flex items-center gap-8">

            <a href="#beranda">Beranda</a>

            <a href="#profil">Profil</a>

            <a href="#potensi">Potensi</a>

            <a href="#galeri">Galeri</a>

            <a href="#kontak" class="btn-kontak">
                Kontak
            </a>

        </nav>

    </div>
</header>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const navbar = document.getElementById("navbar");

        if (!navbar) return;

        const onScroll = () => {
            if (window.scrollY > 20) {
                navbar.classList.add("navbar-scrolled");
            } else {
                navbar.classList.remove("navbar-scrolled");
            }
        };

        onScroll();
        window.addEventListener("scroll", onScroll);
    });
</script>

<style>
.navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 999;

    color: white;

    background: transparent;

    transition:
        background .35s ease,
        backdrop-filter .35s ease,
        box-shadow .35s ease,
        color .35s ease;
}

.navbar a {
    color: inherit;
    transition: color .3s;
}

.navbar a:hover {
    color: #bbf7d0;
}

.btn-kontak {
    border: 1px solid rgba(255,255,255,.7);
    padding: .75rem 1.4rem;
    border-radius: 999px;
    transition: .3s;
}

.btn-kontak:hover {
    background: white;
    color: #166534 !important;
}

/* Saat discroll */
.navbar-scrolled {
    background: rgba(255,255,255,.65);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);

    border-bottom: 1px solid rgba(255,255,255,.3);

    box-shadow: 0 8px 30px rgba(0,0,0,.08);

    color: #1e293b;
}

.navbar-scrolled a:hover {
    color: #16a34a;
}

.navbar-scrolled .btn-kontak {
    border-color: #16a34a;
    color: #16a34a;
}

.navbar-scrolled .btn-kontak:hover {
    background: #16a34a;
    color: white !important;
}
</style>