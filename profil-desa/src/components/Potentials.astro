---
import { Sprout, Fish, ArrowUpRight } from "lucide-astro";
import { village } from "../data/village";

const icons = [Sprout, Fish];
---

<section
    id="potensi"
    class="relative overflow-hidden bg-slate-50 py-32"
>
    <!-- Background Blur -->
    <div class="absolute -left-40 top-0 h-96 w-96 rounded-full bg-green-100/60 blur-[120px]"></div>
    <div class="absolute -right-40 bottom-0 h-96 w-96 rounded-full bg-emerald-100/60 blur-[120px]"></div>

    <div class="container relative z-10 mx-auto px-6">

        <!-- Heading -->
        <div class="mx-auto max-w-3xl text-center">

            <span class="inline-flex rounded-full bg-green-100 px-5 py-2 text-sm font-semibold text-green-700">
                Potensi Desa
            </span>

            <h2 class="mt-6 text-5xl font-black tracking-tight text-slate-900">
                Potensi Unggulan Desa Hukaea
            </h2>

            <p class="mt-6 text-lg leading-8 text-slate-500">
                Desa Hukaea memiliki berbagai potensi yang menjadi sumber
                penghidupan masyarakat serta mendukung pembangunan ekonomi desa.
            </p>

        </div>

        <!-- Cards -->
        <div class="mx-auto mt-20 grid max-w-6xl gap-8 lg:grid-cols-2">

            {
                village.potentials.map((item, index) => {
                    const Icon = icons[index];

                    return (
                        <div
                            class="group overflow-hidden rounded-[32px] border border-white/60 bg-white shadow-[0_15px_45px_rgba(0,0,0,.08)] transition-all duration-500 hover:-translate-y-3 hover:shadow-[0_25px_60px_rgba(22,163,74,.18)]"
                        >
                            {/* Placeholder Gambar */}
                            <div class="flex h-72 items-center justify-center bg-gradient-to-br from-green-50 via-white to-green-100">

                                <div class="flex h-24 w-24 items-center justify-center rounded-3xl bg-green-100 transition duration-500 group-hover:scale-110 group-hover:bg-green-600">

                                    <Icon
                                        class="h-12 w-12 text-green-600 transition duration-500 group-hover:text-white"
                                        strokeWidth={2}
                                    />

                                </div>

                            </div>

                            {/* Content */}
                            <div class="p-8">

                                <h3 class="text-3xl font-bold text-slate-900">
                                    {item.title}
                                </h3>

                                <p class="mt-5 leading-8 text-slate-600">
                                    {item.description}
                                </p>

                                <button
                                    class="group mt-8 inline-flex items-center gap-2 font-semibold text-green-700 transition"
                                >
                                    Selengkapnya

                                    <ArrowUpRight
                                        class="h-5 w-5 transition group-hover:translate-x-1 group-hover:-translate-y-1"
                                    />

                                </button>

                            </div>

                        </div>
                    );
                })
            }

        </div>

    </div>
</section>